        "packages/sangfor-competency/src/index.ts"
      ],
      "@sangfor/rca": [
        "packages/sangfor-rca/src/index.ts"
      ],
      "@sangfor/pm": [
        "packages/sangfor-pm/src/index.ts"
      ],
      "@sangfor/sizing": [
        "packages/sangfor-sizing/src/index.ts"
      ],
      "@sangfor/version": [
        "packages/sangfor-version/src/index.ts"
      ],
