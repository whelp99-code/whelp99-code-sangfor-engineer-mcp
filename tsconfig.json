        "packages/sangfor-wiki/src/index.ts"
      ],
      "@sangfor/planner": [
        "packages/sangfor-planner/src/index.ts"
      ],
      "@sangfor/approval": [
        "packages/sangfor-approval/src/index.ts"
      ],
      "@sangfor/operator": [
        "packages/sangfor-operator/src/index.ts"
      ],
      "@sangfor/verifier": [
        "packages/sangfor-verifier/src/index.ts"
      ],
      "@sangfor/evidence": [
        "packages/sangfor-evidence/src/index.ts"
      ],
      "@sangfor/feedback": [
        "packages/sangfor-feedback/src/index.ts"
      ],
      "@sangfor/evals": [
        "packages/sangfor-evals/src/index.ts"
      ],
      "@sangfor/rag": [
        "packages/sangfor-rag/src/index.ts"
      ],
      "@sangfor/finetune": [
        "packages/sangfor-finetune/src/index.ts"
      ],
      "@sangfor/product-adapters": [
        "packages/sangfor-product-adapters/src/index.ts"
      ],
      "@sangfor/store": [
        "packages/sangfor-store/src/index.ts"
      ],
      "@sangfor/shared": [
        "packages/shared/src/index.ts"
      ],
      "@sangfor/pptx": [
        "packages/sangfor-pptx/src/index.ts"
      ],
      "@sangfor/screenshot": [
        "packages/sangfor-screenshot/src/index.ts"
