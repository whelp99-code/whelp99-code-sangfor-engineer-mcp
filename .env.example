DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sangfor_engineer_mcp"

# --- Sangfor ONE (Partner Portal) https://one.sangfor.com ---
# After login in browser: DevTools → Application → Local Storage → access_token_mh
SANGFOR_ONE_ACCESS_TOKEN=""
# Or one-time OAuth code from redirect URL (?code=...)
SANGFOR_OAUTH_CODE=""
SANGFOR_ONE_BASE_URL="https://one.sangfor.com"

# Knowledge Base (auto-resolved from ONE token when possible, or set manually)
SANGFOR_KB_TOKEN=""
SANGFOR_LIBRARY_TOKEN=""
# Long JWT from KB localStorage (token_by_code) — required for Playwright DOM crawl
SANGFOR_KB_TOKEN_BY_CODE=""
SANGFOR_KB_BASE_URL="https://knowledgebase.sangfor.com"
# Glass CDP — fixed port for daily learn:kb:full (see docs/design/KB_DAILY_CDP_AUTOMATION.md)
SANGFOR_CDP_URL="http://127.0.0.1:9222"
SANGFOR_GLASS_CDP_REQUIRED=1

# Embeddings — LiteLLM proxy | Rapid-MLX | hash (docs/design/RAG_SEMANTIC_EMBEDDINGS.md)
# Use litellm when local LiteLLM proxy is running (OpenAI-compatible /v1)
SANGFOR_EMBEDDING_PROVIDER=litellm
SANGFOR_LITELLM_BASE_URL=http://localhost:4000/v1
SANGFOR_LITELLM_API_KEY=sk-local-master-key-2026
# LiteLLM /v1/models id (CrewAI openai/local-rapid → API는 local-rapid)
SANGFOR_LITELLM_EMBEDDING_MODEL=local-rapid
SANGFOR_MIMO_VIA_LITELLM=1
SANGFOR_LITELLM_CHAT_MODEL=cloud-mimo
# Or use OPENAI_API_BASE / OPENAI_API_KEY in shell (~/.zshrc) — auto-fallback

# Rapid-MLX direct (when SANGFOR_EMBEDDING_PROVIDER=rapid-mlx)
SANGFOR_RAPID_MLX_BASE_URL=http://127.0.0.1:8000/v1
SANGFOR_RAPID_MLX_EMBEDDING_MODEL=mlx-community/nomic-embed-text-v1.5-4bit
# MiMo Token Plan (tp-xxxxx) — default cluster sgp for APAC; cn|sgp|ams
SANGFOR_MIMO_BILLING=token-plan
SANGFOR_MIMO_TOKEN_PLAN_CLUSTER=sgp
SANGFOR_MIMO_API_KEY=""
# Optional override; when unset, Token Plan uses token-plan-{cluster}.xiaomimimo.com/v1
# SANGFOR_MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
SANGFOR_MIMO_CHAT_MODEL=mimo-v2.5-pro
SANGFOR_MIMO_RERANK_ENABLED=1
SANGFOR_ALLOW_CLOUD_RAG=0

# SANGFOR_USE_CHROME_PROFILE=1
# SANGFOR_KB_HEADED=1

# Collection limits: positive number, or "all" / 0 for no cap
SANGFOR_COMMUNITY_MAX_THREADS=12
SANGFOR_KB_MAX_ARTICLES=80
SANGFOR_INCLUDE_DEMO_DOCS=1
SANGFOR_FINETUNE_MAX_EXAMPLES=80

# ─────────────────────────────────────────────────────────────────────────────
# SAFETY GATES & APPROVAL SECRETS (fail-closed — features stay blocked if unset)
# ─────────────────────────────────────────────────────────────────────────────
# Live device execution is OFF unless explicitly enabled. Leave unset for the
# default read-only posture. Enable ONLY in an authorized lab/customer session.
# SANGFOR_ALLOW_REAL_EXECUTION=true
# Additionally required for production-mode sessions, after formal change approval.
# SANGFOR_ALLOW_PRODUCTION_EXECUTION=true

# HMAC secret that signs live-execution approvals (action-bound + expiring).
# Without it, assertRealExecutionAllowed fails closed and no live action runs.
SANGFOR_OPERATOR_APPROVAL_SECRET=""

# (optional) Durable single-use store for approval nonces (rejects replay within
# the expiry window). Default: data/runtime/approval-nonces.json (gitignored).
# SANGFOR_NONCE_STORE_PATH=

# HMAC key for the PM audit event chain. Without it the chain is UNKEYED
# (accidental-corruption detection only, not tamper-evident) and reports say so.
SANGFOR_PM_CHAIN_SECRET=""

# HMAC key for wiki/KB write approvals. The approve token is HMAC(secret,proposalId)
# via mintWikiApproval, so it is bound to one proposal. Without it, approvals fail closed.
SANGFOR_WIKI_APPROVAL_SECRET=""

# HMAC key for the HCI change audit ledger. Without it the ledger chain is UNKEYED
# (keyed:false in verify) — detects accidental corruption, not a knowing tamperer.
SANGFOR_CHANGE_LEDGER_SECRET=""

# HCI/SCP OpenAPI connection. Default is the local mock console; set real values
# ONLY after the M4 real-device gate (see docs plan). Password is a secret — do not commit.
# SANGFOR_HCI_IDENTITY_URL=http://127.0.0.1:3400/openstack/identity/v2.0
# SANGFOR_HCI_TENANT=lab
# SANGFOR_HCI_USER=admin
# SANGFOR_HCI_PASSWORD=

# Screenshot collector target devices. Source ships non-routable placeholders
# (RFC5737 192.0.2.x); set your device web-UI URLs here. Passwords are secrets.
# SANGFOR_EPP_URL=
# SANGFOR_EPP_PASSWORD=
# SANGFOR_IAG_URL=
# SANGFOR_IAG_PASSWORD=
# SANGFOR_CC_URL=
# SANGFOR_CC_PASSWORD=

# HTTP bridge: bearer token + read-only enforcement (see docs/LOCAL_SETUP.md).
# SANGFOR_API_TOKEN=""
# Set to "false" ONLY in trusted dev to permit non-read-only (write) tools;
# destructive tools are refused regardless of this flag.
# WHELP99_ENFORCE_SAFE_TOOLS=true
# On a non-loopback bind, write tools are refused by default even with the
# whitelist off (destructive tools are always refused). Opt in ONLY for an
# authorized deployment (a bearer token is also mandatory on any remote bind).
# SANGFOR_ALLOW_REMOTE_WRITE=

# ── Control Tower (:3700) ─────────────────────────────────────────────────
# 타워 포트 (PORT가 우선한다)
# CONTROL_TOWER_PORT=3700
# 타워가 호출할 http-bridge 주소
# CONTROL_TOWER_BRIDGE_URL=http://127.0.0.1:3600
# 실행이력 JSONL 루트 (기본 <repo>/data/runs — gitignored)
# SANGFOR_RUNS_ROOT=
# 벤더/장비 레지스트리 루트 (기본 <repo>/data/registry)
# SANGFOR_REGISTRY_ROOT=
# 건강도 위젯이 점검할 mock 콘솔 주소
# MOCK_CONSOLE_URL=http://127.0.0.1:3400
